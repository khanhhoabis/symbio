# ------------------------------------------------------------------------------
# Symbio - Hermes Agent Environment Configuration
# Copy this file to '.env' and fill in your keys.
# ------------------------------------------------------------------------------

# Path to your personal Markdown knowledge vault
# Default is "../vault" (relative to the agent directory)
VAULT_PATH=../vault

# LLM Provider: 'gemini' or 'ollama'
LLM_PROVIDER=gemini

# Model Names
# If provider is 'gemini', use models like 'gemini-2.5-flash' or 'gemini-2.0-flash'
# If provider is 'ollama', use models like 'hermes3:8b' or 'llama3'
LLM_MODEL=gemini-2.5-flash

# --- Gemini API Config (Google AI Studio) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Ollama Config (Local LLM) ---
OLLAMA_HOST=http://localhost:11434
